generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NETLIFY_DATABASE_URL")
}

model Lead {
  id           Int      @id @default(autoincrement())
  timestamp    String
  name         String
  phone_prefix String
  phone_middle String
  phone_last   String
  model        String
  carrier      String
  inquiry      String?
  created_at   DateTime @default(now())
}
